{
  "name": "livegauge",
  "version": "0.0.2",
  "description": "Real-time animated gauge chart for React",
  "keywords": [
    "react",
    "chart",
    "canvas",
    "real-time",
    "animation",
    "gauge"
  ],
  "homepage": "https://github.com/brenopolanski/livegauge#readme",
  "bugs": {
    "url": "https://github.com/brenopolanski/livegauge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brenopolanski/livegauge.git"
  },
  "license": "MIT",
  "author": {
    "name": "Breno Polanski",
    "email": "breno.polanski@gmail.com",
    "url": "https://github.com/brenopolanski"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "check": "biome check",
    "ci": "biome ci",
    "clean": "/bin/bash scripts/clean.sh",
    "dev": "tsup --watch",
    "format": "biome check --write",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/react": "^18.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
